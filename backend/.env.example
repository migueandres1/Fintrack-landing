# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS: dominio del landing site ───────────────────────────────────────────
# En desarrollo: http://localhost:5174
# En producción: https://fintrack.com (o tu dominio de landing)
ALLOWED_ORIGIN=https://fintrack.com

# ── URL del app principal (a donde redirige el checkout exitoso) ───────────────
APP_URL=https://app.fintrack.com

# ── Stripe ────────────────────────────────────────────────────────────────────
# Usar claves TEST en desarrollo, LIVE en producción
STRIPE_SECRET_KEY=sk_live_...

# Price IDs — obtenidos desde Stripe Dashboard → Products
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_FAMILIA_MONTHLY=price_...
STRIPE_PRICE_FAMILIA_ANNUAL=price_...
